---
import { SITE, SOCIALS } from "@consts"
import Container from "@components/Container.astro"
---

<footer class="mt-auto" style="border-top: 1px solid var(--bg-border); background-color: var(--bg)">
  <Container size="md">
    <div
      class="animate py-7 flex flex-col sm:flex-row items-center justify-between gap-4"
      style="font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim)"
    >
      <!-- Left: brand + status -->
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-1 transition-colors duration-200 footer-logo">
          <span style="color: var(--cyan)">~/</span>
          <span>{SITE.AUTHOR.toLowerCase().replace(" ", "")}</span>
        </a>
        <span style="color: var(--bg-border)">|</span>
        <span class="flex items-center gap-1.5">
          <span class="relative flex h-1.5 w-1.5">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-50"
              style="background-color: var(--cyan)"
            ></span>
            <span
              class="relative inline-flex rounded-full h-1.5 w-1.5"
              style="background-color: var(--cyan)"
            ></span>
          </span>
          online
        </span>
        <span>&copy; 2026</span>
      </div>

      <!-- Right: socials -->
      <div class="flex items-center gap-4">
        {SOCIALS.map((SOCIAL) => (
          <a
            href={SOCIAL.HREF}
            target="_blank"
            aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
            class="transition-colors duration-200 footer-social"
            style="color: var(--text-dim)"
          >
            <svg class="size-3.5 fill-current">
              <use href={`/social.svg#${SOCIAL.ICON}`} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </Container>
</footer>

<style>
  .footer-logo:hover { color: var(--cyan); }
  .footer-social:hover { color: var(--text); }
</style>
