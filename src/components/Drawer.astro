---
import { LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url
const subpath = pathname.match(/[^/]+/g)
---

<div
  id="drawer"
  class="fixed inset-0 h-0 z-40 overflow-hidden flex flex-col items-center justify-center md:hidden transition-[height] duration-300 ease-in-out"
  style="background-color: var(--bg)"
>
  <nav class="flex flex-col items-center gap-7">
    {
      LINKS.map((LINK) => {
        const isActive =
          pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
        return (
          <a
            href={LINK.HREF}
            class={cn(
              "text-sm uppercase tracking-[0.2em] transition-colors duration-200 flex items-center gap-1.5",
              isActive ? "drawer-active" : "drawer-idle"
            )}
          >
            {isActive && (
              <span style="color: var(--text-dim)" class="text-xs">&gt;</span>
            )}
            {LINK.TEXT}
          </a>
        )
      })
    }
  </nav>
</div>

<style>
  #drawer.open { @apply h-full; }
  .drawer-idle   { color: var(--text-dim); }
  .drawer-idle:hover { color: var(--text); }
  .drawer-active { color: var(--cyan); }
</style>
