---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"

const PAGE = {
  TITLE: "Writing",
  DESCRIPTION: "Technical writing on ML, systems, and engineering craft.",
}

const allPosts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort()

function estimateReadTime(content: string): string {
  const words = content.split(/\s+/).length
  const mins = Math.max(1, Math.ceil(words / 200))
  return `${mins} min read`
}
---

<PageLayout title={PAGE.TITLE} description={PAGE.DESCRIPTION}>
  <div class="pt-28 pb-24 writing-bg">
    <div class="mx-auto max-w-screen-sm px-5">

      <!-- Header -->
      <div class="animate mb-12">
        <p class="cmd-prefix mb-2">$ cat writing/index.md</p>
        <h1 class="page-title">Writing</h1>
        <p class="page-subtitle mt-2">
          Notes on machine learning, system design, and engineering craft.
          Written to think through problems, not to perform expertise.
        </p>
      </div>

      <!-- Tag filter -->
      <div class="animate mb-8">
        <p class="filter-label mb-3">$ filter --tag</p>
        <div class="flex flex-wrap gap-2" id="tag-filters">
          <button
            class="tag-btn tag-all active"
            data-tag="all"
          >
            [ALL]
          </button>
          {allTags.map(tag => (
            <button
              class="tag-btn"
              data-tag={tag}
            >
              [{tag.toUpperCase()}]
            </button>
          ))}
        </div>
      </div>

      <!-- Post list -->
      <div id="post-list" class="space-y-0">
        {allPosts.map((post, i) => (
          <article
            class="animate post-row group"
            data-tags={post.data.tags.join(",")}
            style={`animation-delay: ${i * 0.07}s`}
          >
            <a href={`/blog/${post.slug}`} class="block py-5 post-link">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <h2 class="post-title text-sm font-semibold group-hover:text-[var(--cyan)] transition-colors duration-200 flex-1 min-w-0">
                  {post.data.title}
                </h2>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="post-meta text-[10px]">
                    {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </span>
                </div>
              </div>

              <p class="post-excerpt text-xs leading-relaxed mt-1.5 line-clamp-2">
                {post.data.summary}
              </p>

              <div class="flex flex-wrap gap-1.5 mt-3 items-center">
                {post.data.tags.map(tag => (
                  <span class="post-tag text-[9px]">[{tag}]</span>
                ))}
                <span class="post-meta text-[10px] ml-auto">→</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-12 text-center">
        <p class="empty-text text-xs">// no posts match this filter</p>
      </div>

    </div>
  </div>
</PageLayout>

<style>
  .writing-bg { background-color: var(--bg); }

  .cmd-prefix {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--text-dim);
  }
  .page-title   { color: var(--cyan); font-size: 1.4rem; font-weight: 700; }
  .page-subtitle { font-size: 12px; color: var(--text-dim); line-height: 1.6; }

  /* Tag filters */
  .filter-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-dim); }
  .tag-btn {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 3px 8px;
    border: 1px solid var(--bg-border);
    color: var(--text-dim);
    background: transparent;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.18s, color 0.18s;
  }
  .tag-btn:hover { border-color: var(--cyan); color: var(--cyan); }
  .tag-btn.active { border-color: var(--cyan); color: var(--cyan); }

  /* Posts */
  .post-row {
    border-bottom: 1px solid var(--bg-border);
  }
  .post-row:first-child { border-top: 1px solid var(--bg-border); }
  .post-link { color: inherit; text-decoration: none; display: block; }

  .post-title  { color: var(--text); }
  .post-excerpt { color: var(--text-dim); }
  .post-meta   { color: var(--text-dim); }
  .post-tag    {
    color: var(--text-dim);
    border: 1px solid var(--bg-border);
    padding: 1px 5px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .empty-text { color: var(--text-dim); }
</style>

<script is:inline>
  (function () {
    function initFilter() {
      var buttons = document.querySelectorAll('.tag-btn')
      var posts   = document.querySelectorAll('.post-row')
      var empty   = document.getElementById('empty-state')
      var active  = 'all'

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var tag = this.getAttribute('data-tag')
          active = tag

          // Update button states
          buttons.forEach(function (b) { b.classList.remove('active') })
          this.classList.add('active')

          // Filter posts
          var visible = 0
          posts.forEach(function (post) {
            var tags = (post.getAttribute('data-tags') || '').split(',')
            var show = tag === 'all' || tags.some(function (t) {
              return t.toLowerCase() === tag.toLowerCase()
            })
            post.style.display = show ? '' : 'none'
            if (show) visible++
          })

          if (empty) empty.classList.toggle('hidden', visible > 0)
        })
      })
    }

    document.addEventListener('DOMContentLoaded', initFilter)
    document.addEventListener('astro:after-swap', initFilter)
  })()
</script>
