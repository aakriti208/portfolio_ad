---
import PageLayout from "@layouts/PageLayout.astro";

const PAGE = {
  TITLE: "Chat",
  DESCRIPTION: "Ask Aakriti anything — terminal-style AI chat interface.",
};

const SEED_MESSAGES = [
  {
    role: "system",
    content:
      "Connected to aakriti-assistant v0.1.0 — ask me anything about Aakriti's work, projects, or background.",
  },
];
---

<PageLayout title={PAGE.TITLE} description={PAGE.DESCRIPTION}>
  <div class="pt-14 h-screen flex flex-col chat-layout">
    <!-- Terminal header bar -->
    <div class="terminal-titlebar flex items-center gap-2 px-4 py-2.5 shrink-0">
      <div class="flex gap-1.5">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <span
        class="terminal-title text-[10px] uppercase tracking-[0.25em] mx-auto"
      >
        aakriti-assistant — chat
      </span>
    </div>

    <!-- Messages -->
    <div
      id="messages"
      class="flex-1 overflow-y-auto px-4 py-6 space-y-4 messages-area"
    >
      <!-- Seed: system notice -->
      <div class="msg-system">
        <span class="msg-prefix-system">system</span>
        <span class="msg-content-system">
          Connected to <span class="accent">aakriti-assistant</span> v0.1.0
        </span>
      </div>
      <div class="msg-system">
        <span class="msg-prefix-system">system</span>
        <span class="msg-content-system">
          Type a message below and press <kbd class="kbd">Enter</kbd> to send. Ask
          about projects, work, skills, or anything else.
        </span>
      </div>

      <!-- Example assistant message -->
      <div class="msg-assistant">
        <span class="msg-prefix-assistant">Aakriti:~$</span>
        <span class="msg-content">
          Hey! I'm an AI assistant representing Aakriti's portfolio. Ask me
          about her
          <span class="accent">ML research</span>, <span class="accent"
            >projects</span
          >,
          <span class="accent">tech stack</span>, or anything else you'd like to
          know.
        </span>
      </div>
    </div>

    <!-- Input bar -->
    <div
      class="input-area shrink-0 px-4 py-4"
      style="border-top: 1px solid var(--bg-border)"
    >
      <div class="flex items-center gap-3 max-w-screen-sm mx-auto">
        <span class="input-prompt text-sm shrink-0">&gt;</span>
        <input
          id="chat-input"
          type="text"
          autocomplete="off"
          spellcheck="false"
          placeholder="ask me anything..."
          class="chat-input flex-1 bg-transparent text-sm outline-none border-none"
        />
        <button
          id="send-btn"
          class="send-btn text-[10px] uppercase tracking-[0.15em] px-3 py-1.5 shrink-0"
        >
          send
        </button>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  /* Layout */
  .chat-layout {
    background-color: var(--bg);
  }
  .messages-area {
    background-color: var(--bg);
  }

  /* Title bar */
  .terminal-titlebar {
    background-color: var(--bg-surface);
    border-bottom: 1px solid var(--bg-border);
  }
  .terminal-title {
    color: var(--text-dim);
  }
  .dot {
    display: inline-block;
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot-red {
    background-color: #ff5f57;
  }
  .dot-yellow {
    background-color: #febc2e;
  }
  .dot-green {
    background-color: #28c840;
  }

  /* Messages */
  .msg-system {
    display: flex;
    gap: 0.75rem;
    font-size: 11px;
    letter-spacing: 0.03em;
    align-items: baseline;
  }
  .msg-prefix-system {
    color: var(--text-dim);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
  }
  .msg-content-system {
    color: var(--text-dim);
  }

  .msg-assistant,
  .msg-user {
    display: flex;
    gap: 0.75rem;
    font-size: 13px;
    line-height: 1.65;
    align-items: baseline;
  }
  .msg-prefix-assistant {
    color: var(--cyan);
    font-size: 10.5px;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .msg-prefix-user {
    color: var(--text-dim);
    font-size: 10.5px;
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .msg-content {
    color: var(--text);
  }
  .accent {
    color: var(--cyan);
  }

  /* Typing indicator */
  .typing-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--cyan);
    animation: typing-bounce 1.2s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  .typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }
  @keyframes typing-bounce {
    0%,
    80%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    40% {
      transform: translateY(-5px);
      opacity: 1;
    }
  }

  /* Input */
  .input-area {
    background-color: var(--bg-surface);
  }
  .input-prompt {
    color: var(--cyan);
  }
  .chat-input {
    color: var(--text);
    caret-color: var(--cyan);
    font-family: inherit;
  }
  .chat-input::placeholder {
    color: var(--text-dim);
  }

  .send-btn {
    border: 1px solid var(--bg-border);
    color: var(--text-dim);
    transition:
      border-color 0.18s,
      color 0.18s;
    font-family: inherit;
    cursor: pointer;
    background: transparent;
  }
  .send-btn:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  /* Kbd */
  kbd.kbd {
    font-family: inherit;
    font-size: 10px;
    padding: 1px 4px;
    border: 1px solid var(--bg-border);
    color: var(--text-dim);
    border-radius: 2px;
  }

  /* Scrollbar */
  .messages-area::-webkit-scrollbar {
    width: 4px;
  }
  .messages-area::-webkit-scrollbar-track {
    background: transparent;
  }
  .messages-area::-webkit-scrollbar-thumb {
    background-color: var(--bg-border);
    border-radius: 2px;
  }
</style>

<script is:inline>
  (function () {
    var REPLIES = [
      "I'm a placeholder for now — Aakriti is working on connecting me to a real model. Check back soon!",
      "Great question! Aakriti specialises in full-stack engineering, ML research, and UI/UX design.",
      "Her tech stack includes Python, TypeScript, React, Next.js, TensorFlow, and more — check the resume page for the full list.",
      "Aakriti is currently a grad researcher at Texas State University, working on an NSF-funded project in NLP and Deep Learning.",
      "She previously worked at Heubert for two years, building scalable enterprise software.",
      "You can reach her at aakritidh208@gmail.com or on LinkedIn.",
    ];
    var replyIdx = 0;

    function scrollToBottom() {
      var msgs = document.getElementById("messages");
      if (msgs) msgs.scrollTop = msgs.scrollHeight;
    }

    function appendMessage(prefix, prefixClass, content, contentClass) {
      var msgs = document.getElementById("messages");
      if (!msgs) return;
      var row = document.createElement("div");
      row.className =
        prefixClass === "msg-prefix-user" ? "msg-user" : "msg-assistant";
      var pre = document.createElement("span");
      pre.className = prefixClass;
      pre.textContent = prefix;
      var body = document.createElement("span");
      body.className = contentClass;
      body.textContent = content;
      row.appendChild(pre);
      row.appendChild(body);
      msgs.appendChild(row);
      scrollToBottom();
    }

    function showTyping() {
      var msgs = document.getElementById("messages");
      if (!msgs) return null;
      var row = document.createElement("div");
      row.className = "msg-assistant";
      row.id = "typing-indicator";
      var pre = document.createElement("span");
      pre.className = "msg-prefix-assistant";
      pre.textContent = "Aakriti:~$";
      var dots = document.createElement("span");
      dots.className = "msg-content flex items-center gap-1";
      dots.innerHTML =
        '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
      row.appendChild(pre);
      row.appendChild(dots);
      msgs.appendChild(row);
      scrollToBottom();
      return row;
    }

    function send() {
      var input = document.getElementById("chat-input");
      if (!input) return;
      var text = input.value.trim();
      if (!text) return;
      input.value = "";

      appendMessage("you:~$", "msg-prefix-user", text, "msg-content");

      var typingRow = showTyping();
      var delay = 900 + Math.random() * 600;

      setTimeout(function () {
        if (typingRow) typingRow.remove();
        var reply = REPLIES[replyIdx % REPLIES.length];
        replyIdx++;
        appendMessage(
          "Aakriti:~$",
          "msg-prefix-assistant",
          reply,
          "msg-content"
        );
      }, delay);
    }

    function init() {
      var input = document.getElementById("chat-input");
      var btn = document.getElementById("send-btn");
      if (!input || !btn) return;

      input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") send();
      });
      btn.addEventListener("click", send);
      scrollToBottom();
    }

    document.addEventListener("DOMContentLoaded", init);
    document.addEventListener("astro:after-swap", init);
  })();
</script>
